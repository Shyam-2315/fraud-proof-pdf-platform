APP_ENV=development
APP_NAME=PDFCraft
APP_PORT=8025
APP_HOST=0.0.0.0

FRONTEND_URL=http://localhost:3025
BACKEND_PUBLIC_URL=http://localhost:8025

CORS_ORIGINS=http://localhost:3025,http://127.0.0.1:3025

MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=fraud_pdf

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-me-super-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

ADMIN_API_KEY=change-me-admin-key
DEFAULT_ADMIN_EMAIL=admin@pdfcraft.local
DEFAULT_ADMIN_PASSWORD=AdminPassword123
DEFAULT_ADMIN_NAME=PDFCraft Admin
ENABLE_DEFAULT_ADMIN_SEED=true

PDF_STORAGE_DIR=storage/generated_pdfs

SECURE_COOKIES=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=

ENABLE_IP_INTELLIGENCE=false
IP_INTELLIGENCE_PROVIDER=LOCAL

LOG_LEVEL=INFO
JSON_LOGS=true

RATE_LIMIT_ENABLED=true

ML_MODELS_DIR=models/fraud
ML_AUTO_LOAD_ACTIVE_MODEL=true

ENABLE_API_DOCS=true
WEB_CONCURRENCY=1
