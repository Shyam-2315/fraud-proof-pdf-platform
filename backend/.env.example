APP_ENV=development
APP_NAME=PDFCraft
APP_PORT=8025
APP_HOST=0.0.0.0

FRONTEND_URL=http://localhost:3025
ADMIN_FRONTEND_URL=http://localhost:3035
BACKEND_PUBLIC_URL=http://localhost:8025

CORS_ORIGINS=http://localhost:3025,http://127.0.0.1:3025,http://localhost:3035,http://127.0.0.1:3035

MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=fraud_pdf

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-me-super-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_PROVIDER=SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-account@gmail.com
SMTP_PASSWORD=REPLACE_WITH_ROTATED_GMAIL_APP_PASSWORD
SMTP_FROM_EMAIL=your-gmail-account@gmail.com
SMTP_FROM_NAME=PDFCraft
SMTP_USE_TLS=true
EMAIL_VERIFICATION_OTP_TTL_MINUTES=10
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
ENABLE_DISPOSABLE_EMAIL_BLOCK=true
ENABLE_EMAIL_MX_CHECK=false
FREE_USAGE_LIMIT=2
ENABLE_SHARED_IP_ANON_QUOTA=true
ANON_SHARED_IP_FREE_LIMIT=2
ANON_IP_USAGE_WINDOW_HOURS=24

ADMIN_API_KEY=change-me-admin-key
DEFAULT_ADMIN_EMAIL=admin@pdfcraft.local
DEFAULT_ADMIN_PASSWORD=AdminPassword123
DEFAULT_ADMIN_NAME=PDFCraft Admin
ENABLE_DEFAULT_ADMIN_SEED=true

PDF_STORAGE_DIR=storage/generated_pdfs

SECURE_COOKIES=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=

ENABLE_IP_INTELLIGENCE=false
IP_INTELLIGENCE_PROVIDER=LOCAL
IP_INTELLIGENCE_API_KEY=

LOG_LEVEL=INFO
JSON_LOGS=true

RATE_LIMIT_ENABLED=true
VISITOR_IDENTIFY_RATE_LIMIT=30/minute
VISITOR_STATUS_RATE_LIMIT=60/minute
PDF_GENERATE_RATE_LIMIT=5/minute
AUTH_LOGIN_RATE_LIMIT=5/minute
AUTH_REGISTER_RATE_LIMIT=3/hour
AUTH_VERIFY_EMAIL_RATE_LIMIT=5/minute
AUTH_RESEND_VERIFICATION_RATE_LIMIT=3/hour
ADMIN_RATE_LIMIT=120/minute

ML_MODELS_DIR=models/fraud
ML_AUTO_LOAD_ACTIVE_MODEL=true
ENABLE_ONLINE_ML_TRAINING=true

ENABLE_API_DOCS=true
WEB_CONCURRENCY=1
