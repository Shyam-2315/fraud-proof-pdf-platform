APP_ENV=production
APP_NAME=PDFCraft
APP_PORT=8025
APP_HOST=0.0.0.0

FRONTEND_URL=https://your-domain.com
BACKEND_PUBLIC_URL=https://api.your-domain.com
CORS_ORIGINS=https://your-domain.com

MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=fraud_pdf

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

ADMIN_API_KEY=replace-with-strong-admin-key
DEFAULT_ADMIN_EMAIL=admin@pdfcraft.local
DEFAULT_ADMIN_PASSWORD=replace-with-strong-admin-password
DEFAULT_ADMIN_NAME=PDFCraft Admin
ENABLE_DEFAULT_ADMIN_SEED=false

PDF_STORAGE_DIR=storage/generated_pdfs

SECURE_COOKIES=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_IPS=172.25.0.0/16

ENABLE_IP_INTELLIGENCE=false
IP_INTELLIGENCE_PROVIDER=LOCAL

LOG_LEVEL=INFO
JSON_LOGS=true

RATE_LIMIT_ENABLED=true

ML_MODELS_DIR=models/fraud
ML_AUTO_LOAD_ACTIVE_MODEL=true

ENABLE_API_DOCS=false
WEB_CONCURRENCY=2
